# Copy to .env and fill in. LocalStack requires an auth token since v2026.03.0.
# A free Hobby-plan token (non-commercial use) works for s3, sqs, and lambda.
# Get one at https://app.localstack.cloud
LOCALSTACK_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Operational tuning. These map to common.config.Settings (env prefix
# SCHEDULER_). Read on the host (pytest, alembic, one-off scripts) and injected
# into the service containers via docker-compose `env_file`. Change a value
# here and `make up` to retune — no code edit needed. Values below are the
# defaults; uncomment/edit to override.
# ---------------------------------------------------------------------------

# Scheduler: per-contact local calling window (24h clock) and loop tuning.
# SCHEDULER_WINDOW_START_HOUR=8
# SCHEDULER_WINDOW_END_HOUR=21
# SCHEDULER_BATCH_SIZE=50
# SCHEDULER_POLL_INTERVAL_SECONDS=5
# Reaper: reclaim tasks stuck in dispatching/calling longer than this.
# SCHEDULER_STUCK_AFTER_SECONDS=120

# Dashboard: how often the SSE stream pushes a fresh snapshot (seconds).
# SCHEDULER_DASHBOARD_INTERVAL_SECONDS=0.5
