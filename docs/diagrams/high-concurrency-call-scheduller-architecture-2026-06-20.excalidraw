    {
      "id": "B5Whb6f9Sd-IVIMBHxxke",
      "type": "text",
      "x": 610.16796875,
      "y": 180.34375,
      "width": 1163.37890625,
      "height": 825,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
